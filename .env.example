# Telegram Bot Token
# Obtén uno hablando con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# GitHub Token con acceso a Copilot
# Genera uno en: https://github.com/settings/tokens
# Necesita scopes: repo, copilot
GITHUB_TOKEN=your_github_token_here

# Repositorio SICEM
SICEM_REPO_OWNER=your_github_username
SICEM_REPO_NAME=SICEM
SICEM_REPO_BRANCH=main

# Ruta local donde se clonará el repositorio
# El bot trabajará directamente en esta carpeta
SICEM_REPO_PATH=./workspace/sicem

# OpenAI API Key (opcional, solo para transcripción de voz)
OPENAI_API_KEY=your_openai_api_key_here

# Usuarios autorizados (IDs de Telegram separados por coma)
# Deja vacío para permitir a todos
AUTHORIZED_USERS=

# Copilot Model (opcional)
# Opciones: claude-sonnet-4.5, gpt-4o, etc.
COPILOT_MODEL=claude-sonnet-4.5

# Log Level (opcional)
LOG_LEVEL=info

# Environment
NODE_ENV=development
